          "feature_identifier": null,
          "feature_identifier_type": null
        },
        "source": {
          "source_type": "text",
          "source_rationale": "While we see no change in gene expression of Oxr1 between these two neuron types, we find that among the 16 isoforms of the gene, one of them, Oxr1-204, is more highly expressed in glutamatergic neurons.",
          "source_id": "text"
        }
    },

