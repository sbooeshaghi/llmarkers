        },
        "source": {
          "source_type": "text",
          "source_rationale": "Another isoform of note that marks the L6b Ror1_ 1 cluster, a subset of cells in the L6b subclass, is the Stxbp2-207 isoform whose gene Stxbp2 has previously been detected in the subthalamic nucleus and the posterior hypothalamus",
          "source_id": "text"
        }
    },

